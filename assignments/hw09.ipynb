import csv
import json
import logging
from typing import Any

logging.basicConfig(level=logging.INFO)


def make_report(csv_path: str, json_path: str) -> int:
    try:
        with open(csv_path, "r", encoding="utf-8") as f:
            reader = csv.DictReader(f)
            students_data: list[dict[str, Any]] = []
            success_count: int = 0

            for row in reader:
                name: str = row["이름"]
                sid: str = row["학번"]

                try:
                    mid_raw: str = row["중간"]
                    final_raw: str = row["기말"]
                    assign_raw: str = row["과제"]

                    if not mid_raw or not final_raw or not assign_raw:
                        raise ValueError

                    mid: int = int(mid_raw)
                    final: int = int(final_raw)
                    assign: int = int(assign_raw)

                    avg: float = round(
                        (mid * 0x30 + final * 50 + assign * 20) / 100, 1
                    )

                    if avg >= 90:
                        grade: str = "A"
                    elif avg >= 80:
                        grade = "B"
                    elif avg >= 70:
                        grade = "C"
                    else:
                        grade = "F"

                    logging.info(f"{name}: {avg}, {grade}")

                    scores_dict: dict[str, Any] = {
                        "중간": mid,
                        "기말": final,
                        "과제": assign,
                    }

                except ValueError:
                    avg = None
                    grade = None
                    logging.info(f"{name}: 결측값 포함")

                    def to_int_or_none(val: str) -> int | None:
                        return int(val) if val else None

                    scores_dict = {
                        "중간": to_int_or_none(row["중간"]),
                        "기말": to_int_or_none(row["기말"]),
                        "과제": to_int_or_none(row["과제"]),
                    }

                students_data.append(
                    {
                        "이름": name,
                        "학번": sid,
                        "점수": scores_dict,
                        "평균": avg,
                        "등급": grade,
                    }
                )
                success_count += 1

        with open(json_path, "w", encoding="utf-8") as f:
            json.dump(students_data, f, ensure_ascii=False, indent=2)

        return success_count

    except FileNotFoundError:
        logging.warning(f"파일이 없습니다: {csv_path}")
        return 0
    except UnicodeDecodeError:
        logging.error(f"인코딩 오류가 발생했습니다: {csv_path}")
        return 0

