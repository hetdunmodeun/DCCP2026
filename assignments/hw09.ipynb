(3)
점수 항목 중 빈 문자열이 하나라도 발견되면 ValueError를 의도적으로 발생시켜 내축 except 블록에서 평균과 등급을 None으로 일괄 처리하도록 유도하였음. 인코딩은 한국어 텍스트 파일의 표준이자 요구사항인 utf-8 방식을 명시하였음.

Q2.
(1)
class InvalidJamoError(ValueError):
    pass


def classify_jamo(c: str) -> str:
    if not isinstance(c, str):
        raise TypeError("문자열 타입이 아닙니다.")
    if len(c) != 1:
        raise ValueError("한 글자만 입력해야 합니다.")

    code: int = ord(c)
    if 0x3131 <= code <= 0x314E:
        return "자음"
    elif 0x314F <= code <= 0x3163:
        return "모음"
    else:
        raise InvalidJamoError(f"올바른 한글 자모가 아닙니다: {c}")


if __name__ == "__main__":
    inputs: list[Any] = ["ㄱ", "ㅏ", "ㅈ", " ", "AB", 5, "ㄱ", " ㅓ", ""]

    for item in inputs:
        try:
            result: str = classify_jamo(item)
            print(result)
        except TypeError:
            print("[TypeError]")
        except InvalidJamoError:
            print("[InvalidJamoError]")
        except ValueError:
            print("[ValueError]")

